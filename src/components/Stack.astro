---
import Section from "./Section.astro";
import { SITE_CONTENT } from "../config"; // Sesuaikan path-nya
---

<Section text="Stack" href="stack">
  <div class="sticky mb-12 rounded-2xl border border-neutral/20 bg-black p-8">
    <div class="flex flex-col gap-10">
      {
        SITE_CONTENT.skills.map((section) => (
          <div class="skill-category">
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-neutral-400 uppercase">
              {section.category}
            </h3>
            <div class="flex flex-wrap gap-4">
              {section.items.map((item) => (
                <div
                  class="group relative flex h-20 w-20 items-center justify-center rounded-xl bg-slate-500 p-3 transition-all hover:scale-110 hover:bg-[#252d38]"
                  title={item.name}
                >
                  <img
                    src={item.image}
                    alt={item.name}
                    class="h-full w-full object-contain"
                  />
                  {/* Tooltip simple */}
                  <span class="absolute -bottom-8 scale-0 rounded bg-white px-2 py-1 text-xs text-black transition-all group-hover:scale-100">
                    {item.name}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Section>
